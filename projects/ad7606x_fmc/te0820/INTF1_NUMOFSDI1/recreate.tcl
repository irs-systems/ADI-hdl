# Hierarchical cell: spi_ad7606
proc create_hier_cell_spi_ad7606 { parentCell nameHier } {

  variable script_folder

  if { $parentCell eq "" || $nameHier eq "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2092 -severity "ERROR" "create_hier_cell_spi_ad7606() - Empty argument(s)!"}
     return
  }

  # Get object for parentCell
  set parentObj [get_bd_cells $parentCell]
  if { $parentObj == "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2090 -severity "ERROR" "Unable to find parent cell <$parentCell>!"}
     return
  }

  # Make sure parentObj is hier blk
  set parentType [get_property TYPE $parentObj]
  if { $parentType ne "hier" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2091 -severity "ERROR" "Parent <$parentObj> has TYPE = <$parentType>. Expected to be <hier>."}
     return
  }

  # Save current instance; Restore later
  set oldCurInst [current_bd_instance .]

  # Set parent object as current
  current_bd_instance $parentObj

  # Create cell and set as current instance
  set hier_obj [create_bd_cell -type hier $nameHier]
  current_bd_instance $hier_obj

  # Create interface pins
  create_bd_intf_pin -mode Master -vlnv analog.com:interface:spi_engine_rtl:1.0 m_spi

  create_bd_intf_pin -mode Master -vlnv xilinx.com:interface:axis_rtl:1.0 m_axis_sample

  create_bd_intf_pin -mode Slave -vlnv xilinx.com:interface:aximm_rtl:1.0 s_axi


  # Create pins
  create_bd_pin -dir I -type clk spi_clk
  create_bd_pin -dir I -type clk clk
  create_bd_pin -dir I -type rst resetn
  create_bd_pin -dir I trigger
  create_bd_pin -dir O irq
  create_bd_pin -dir O -type rst spi_resetn

  # Create instance: spi_ad7606_execution, and set properties
  set spi_ad7606_execution [ create_bd_cell -type ip -vlnv analog.com:user:spi_engine_execution:1.0 spi_ad7606_execution ]
  set_property -dict [list \
    CONFIG.DATA_WIDTH {32} \
    CONFIG.ECHO_SCLK {false} \
    CONFIG.NUM_OF_CS {1} \
    CONFIG.NUM_OF_SDI {1} \
    CONFIG.SDI_DELAY {true} \
    CONFIG.SDO_DEFAULT {1} \
  ] $spi_ad7606_execution


  # Create instance: spi_ad7606_axi_regmap, and set properties
  set spi_ad7606_axi_regmap [ create_bd_cell -type ip -vlnv analog.com:user:axi_spi_engine:1.0 spi_ad7606_axi_regmap ]
  set_property -dict [list \
    CONFIG.ASYNC_SPI_CLK {true} \
    CONFIG.CMD_FIFO_ADDRESS_WIDTH {4} \
    CONFIG.DATA_WIDTH {32} \
    CONFIG.MM_IF_TYPE {0} \
    CONFIG.NUM_OF_SDI {1} \
    CONFIG.OFFLOAD0_CMD_MEM_ADDRESS_WIDTH {4} \
    CONFIG.OFFLOAD0_SDO_MEM_ADDRESS_WIDTH {4} \
    CONFIG.OFFLOAD_EN {1} \
    CONFIG.SDI_FIFO_ADDRESS_WIDTH {5} \
    CONFIG.SDO_FIFO_ADDRESS_WIDTH {5} \
    CONFIG.SYNC_FIFO_ADDRESS_WIDTH {4} \
  ] $spi_ad7606_axi_regmap


  # Create instance: spi_ad7606_offload, and set properties
  set spi_ad7606_offload [ create_bd_cell -type ip -vlnv analog.com:user:spi_engine_offload:1.0 spi_ad7606_offload ]
  set_property -dict [list \
    CONFIG.ASYNC_SPI_CLK {false} \
    CONFIG.ASYNC_TRIG {false} \
    CONFIG.CMD_MEM_ADDRESS_WIDTH {4} \
    CONFIG.DATA_WIDTH {32} \
    CONFIG.NUM_OF_SDI {1} \
    CONFIG.SDO_MEM_ADDRESS_WIDTH {4} \
    CONFIG.SDO_STREAMING {false} \
  ] $spi_ad7606_offload


  # Create instance: spi_ad7606_interconnect, and set properties
  set spi_ad7606_interconnect [ create_bd_cell -type ip -vlnv analog.com:user:spi_engine_interconnect:1.0 spi_ad7606_interconnect ]
  set_property -dict [list \
    CONFIG.DATA_WIDTH {32} \
    CONFIG.NUM_OF_SDI {1} \
  ] $spi_ad7606_interconnect


  # Create interface connections
  connect_bd_intf_net -intf_net Conn1 [get_bd_intf_pins spi_ad7606_axi_regmap/s_axi] [get_bd_intf_pins s_axi]
  connect_bd_intf_net -intf_net spi_ad7606_axi_regmap_spi_engine_ctrl [get_bd_intf_pins spi_ad7606_axi_regmap/spi_engine_ctrl] [get_bd_intf_pins spi_ad7606_interconnect/s1_ctrl]
  connect_bd_intf_net -intf_net spi_ad7606_axi_regmap_spi_engine_offload_ctrl0 [get_bd_intf_pins spi_ad7606_axi_regmap/spi_engine_offload_ctrl0] [get_bd_intf_pins spi_ad7606_offload/spi_engine_offload_ctrl]
  connect_bd_intf_net -intf_net spi_ad7606_execution_spi [get_bd_intf_pins spi_ad7606_execution/spi] [get_bd_intf_pins m_spi]
  connect_bd_intf_net -intf_net spi_ad7606_interconnect_m_ctrl [get_bd_intf_pins spi_ad7606_interconnect/m_ctrl] [get_bd_intf_pins spi_ad7606_execution/ctrl]
  connect_bd_intf_net -intf_net spi_ad7606_offload_m_interconnect_ctrl [get_bd_intf_pins spi_ad7606_offload/m_interconnect_ctrl] [get_bd_intf_pins spi_ad7606_interconnect/s_interconnect_ctrl]
  connect_bd_intf_net -intf_net spi_ad7606_offload_offload_sdi [get_bd_intf_pins spi_ad7606_offload/offload_sdi] [get_bd_intf_pins m_axis_sample]
  connect_bd_intf_net -intf_net spi_ad7606_offload_spi_engine_ctrl [get_bd_intf_pins spi_ad7606_offload/spi_engine_ctrl] [get_bd_intf_pins spi_ad7606_interconnect/s0_ctrl]

  # Create port connections
  connect_bd_net -net clk_1  [get_bd_pins clk] \
  [get_bd_pins spi_ad7606_axi_regmap/s_axi_aclk]
  connect_bd_net -net resetn_1  [get_bd_pins resetn] \
  [get_bd_pins spi_ad7606_axi_regmap/s_axi_aresetn]
  connect_bd_net -net spi_ad7606_axi_regmap_irq  [get_bd_pins spi_ad7606_axi_regmap/irq] \
  [get_bd_pins irq]
  connect_bd_net -net spi_ad7606_axi_regmap_spi_resetn  [get_bd_pins spi_ad7606_axi_regmap/spi_resetn] \
  [get_bd_pins spi_ad7606_execution/resetn] \
  [get_bd_pins spi_ad7606_offload/spi_resetn] \
  [get_bd_pins spi_ad7606_interconnect/resetn] \
  [get_bd_pins spi_resetn]
  connect_bd_net -net spi_clk_1  [get_bd_pins spi_clk] \
  [get_bd_pins spi_ad7606_axi_regmap/spi_clk] \
  [get_bd_pins spi_ad7606_execution/clk] \
  [get_bd_pins spi_ad7606_offload/spi_clk] \
